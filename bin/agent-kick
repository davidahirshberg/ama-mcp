#!/bin/bash
# Usage: agent-kick <window-id|pattern>
# Notifies a kitty window: ESC (interrupts blocking calls) + 📬.
# If idle, sends Enter too so the agent processes it immediately.
# Message content lives in the state file — recipients read via my_task().
BIN="$(cd "$(dirname "$0")" && pwd)"
SOCK=$(ls -t /tmp/kitty-sock-* 2>/dev/null | head -1)
[ -z "$SOCK" ] && { echo "no kitty socket found" >&2; exit 1; }

pattern="$1"
match=""
if [[ "$pattern" =~ ^[0-9]+$ ]]; then
    match="id:$pattern"
else
    match="title:$pattern"
fi

# ESC interrupts blocking tool calls (wait_for_any, wait_for_task)
kitty @ --to "unix:$SOCK" send-key --match "$match" escape 2>/dev/null || { echo "no window found matching: $pattern" >&2; exit 1; }
sleep 0.1

if "$BIN/agent-idle" "$pattern" 2>/dev/null; then
    kitty @ --to "unix:$SOCK" send-text --match "$match" '📬\r' 2>/dev/null
    echo "kicked $match"
else
    kitty @ --to "unix:$SOCK" send-text --match "$match" '📬' 2>/dev/null
    echo "nudged $match"
fi
