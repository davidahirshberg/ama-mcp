#!/bin/bash
# Usage: agent-ask <window-id|pattern> <message>
# Matches by window ID first, then falls back to title pattern
SOCK=$(ls -t /tmp/kitty-sock-* 2>/dev/null | head -1)
[ -z "$SOCK" ] && { echo "no kitty socket found" >&2; exit 1; }

pattern="$1"
shift
message="$*"

# Try matching by window id first, then by title
match=""
if [[ "$pattern" =~ ^[0-9]+$ ]]; then
    match="id:$pattern"
else
    match="title:$pattern"
fi

# Escape backslashes so kitty's Python escape interpreter doesn't mangle \n etc.
escaped=$(printf '%s' "$message" | sed 's/\\/\\\\/g')
# Send text + enter back-to-back with no sleep — the old 0.2s sleep between them caused the race.
kitty @ --to "unix:$SOCK" send-text --match "$match" "$escaped" 2>/dev/null || { echo "no window found matching: $pattern" >&2; exit 1; }
kitty @ --to "unix:$SOCK" send-key --match "$match" enter 2>/dev/null
echo "sent to $match"
